# Application settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# Database settings
MEMGRAPH_URI=bolt://localhost:7687
MEMGRAPH_USER=mg_user
MEMGRAPH_PASSWORD=mg_password
MEMGRAPH_DATABASE=memgraph

# Authentication (JWT 8h)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# LDAP / AD
AD_SERVER=
AD_DOMAIN=
AD_SEARCH_BASE=
AD_TIMEOUT=30
AD_PORT=389
AD_USE_SSL=0
AD_USER=
AD_USER_PASSWORD=
AD_POOL_SIZE=3
AD_POOL_LIFETIME=600

# Demo login when AD is not configured or unreachable (e.g. dev/local)
DEMO_LOGIN_ENABLED=false
DEMO_USERNAME=demo
DEMO_PASSWORD=demo

# Access allowlist: only these usernames can log in (SQLite app/data/access_allowlist.db)
ACCESS_ALLOWLIST_ENABLED=true
ACCESS_LIST_ADMIN_SECRET=change-this-secret

# Redis (for Celery and caching)
REDIS_URL=redis://localhost:6379/0
# Compliance API cache: set to true to cache departments, statuses, and records in Redis
USE_REDIS_CACHE=true
REDIS_CACHE_TTL=300
# Serve compliance from SQLite (app/data/compliance.db) for lower latency; import runs at startup
USE_COMPLIANCE_SQLITE=true

# WebSocket settings
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=1000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS settings
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001"]

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Background tasks
ENABLE_BACKGROUND_TASKS=true
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TRANSACTIONS=fraud-transactions
KAFKA_TOPIC_ALERTS=fraud-alerts

# Monitoring and metrics
ENABLE_METRICS=true
METRICS_PORT=9090

# Development settings
RELOAD=true
WORKERS=1

# SMTP / Mail (Office 365) - copy to .env and set real credentials
MAIL_SERVER=smtp.office365.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=
